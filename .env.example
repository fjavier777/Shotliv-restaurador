# ─────────────────────────────────────────────
#  RESTAURADOR DE FOTOS ANTIGAS · Config
# ─────────────────────────────────────────────

# Google OAuth 2.0
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

# Gemini API Key
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_gemini_api_key_aqui

# Sessão (gere uma string aleatória longa)
SESSION_SECRET=troque_por_uma_string_secreta_aleatoria_longa

# URL do site (sem barra no final)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-site.vercel.app
BASE_URL=http://localhost:3000

# Porta local (só para desenvolvimento)
PORT=3000
